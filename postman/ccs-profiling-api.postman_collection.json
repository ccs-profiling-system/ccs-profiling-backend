{
  "info": {
    "name": "CCS Profiling API - Complete",
    "description": "Complete API collection for CCS Profiling System including Research module",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Research",
      "description": "Research management endpoints with authors and advisers - Admin only",
      "item": [
        {
          "name": "Get All Research",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/research?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "research"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Items per page"
                },
                {
                  "key": "search",
                  "value": "",
                  "description": "Search by title",
                  "disabled": true
                },
                {
                  "key": "research_type",
                  "value": "",
                  "description": "Filter by type (thesis, capstone, publication)",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "",
                  "description": "Filter by status (ongoing, completed, published)",
                  "disabled": true
                }
              ]
            },
            "description": "Get paginated list of research projects. Supports search and filtering.\n\nResearch Types:\n- thesis: Graduate thesis research\n- capstone: Undergraduate capstone projects\n- publication: Published research papers\n\nStatus Values:\n- ongoing: Research in progress\n- completed: Research completed but not published\n- published: Research completed and published\n\nEach research includes:\n- Basic research information\n- Authors array with student details and author order\n- Advisers array with faculty details and adviser roles\n- Timestamps"
          },
          "response": []
        },
        {
          "name": "Get Research by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/research/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "research", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "research-uuid-here",
                  "description": "Research UUID"
                }
              ]
            },
            "description": "Get research details by UUID. Returns complete research information including all authors and advisers."
          },
          "response": []
        },
        {
          "name": "Create Research",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Machine Learning Applications in Healthcare\",\n  \"abstract\": \"A comprehensive study on applying machine learning techniques to healthcare diagnostics and patient care optimization.\",\n  \"research_type\": \"thesis\",\n  \"status\": \"ongoing\",\n  \"start_date\": \"2026-01-15\",\n  \"author_ids\": [\"student-uuid-1\", \"student-uuid-2\"],\n  \"adviser_ids\": [\"faculty-uuid-1\"]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/research",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "research"]
            },
            "description": "Create new research project with authors and advisers in a single transaction.\n\nRequired fields:\n- title: Research title (max 500 characters)\n- research_type: One of: thesis, capstone, publication\n- author_ids: Array of student UUIDs (at least one required)\n- adviser_ids: Array of faculty UUIDs (at least one required)\n\nOptional fields:\n- abstract: Research abstract/summary\n- status: One of: ongoing (default), completed, published\n- start_date: Start date in YYYY-MM-DD format\n- completion_date: Completion date in YYYY-MM-DD format\n- publication_url: URL to published paper\n\nTransaction Safety:\n- All authors and advisers are added in a single database transaction\n- If any step fails, the entire operation is rolled back\n- Ensures data consistency"
          },
          "response": []
        },
        {
          "name": "Update Research",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Research Title\",\n  \"status\": \"completed\",\n  \"completion_date\": \"2026-12-31\",\n  \"publication_url\": \"https://doi.org/10.1234/example\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/research/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "research", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "research-uuid-here",
                  "description": "Research UUID"
                }
              ]
            },
            "description": "Update research information. All fields are optional. Only provided fields will be updated.\n\nNote: To update authors or advisers, use the dedicated endpoints:\n- POST /:id/authors to add authors\n- DELETE /:id/authors/:studentId to remove authors\n- POST /:id/advisers to add advisers\n- DELETE /:id/advisers/:facultyId to remove advisers"
          },
          "response": []
        },
        {
          "name": "Delete Research (Soft Delete)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/research/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "research", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "research-uuid-here",
                  "description": "Research UUID"
                }
              ]
            },
            "description": "Soft delete research (sets deleted_at timestamp). The research will no longer appear in queries but data is preserved for audit purposes.\n\nNote: This does not delete the author and adviser relationships, but they won't be accessible through the API after soft delete."
          },
          "response": []
        },
        {
          "name": "Add Author to Research",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"student_id\": \"student-uuid-here\",\n  \"author_order\": 2\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/research/:id/authors",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "research", ":id", "authors"],
              "variable": [
                {
                  "key": "id",
                  "value": "research-uuid-here",
                  "description": "Research UUID"
                }
              ]
            },
            "description": "Add an author to existing research.\n\nRequired fields:\n- student_id: Student UUID\n- author_order: Order of authorship (1 = first author, 2 = second author, etc.)\n\nValidation:\n- Prevents duplicate authors (same student cannot be added twice)\n- Returns 409 Conflict if author already exists\n- Verifies student exists before adding"
          },
          "response": []
        },
        {
          "name": "Remove Author from Research",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/research/:id/authors/:studentId",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "research", ":id", "authors", ":studentId"],
              "variable": [
                {
                  "key": "id",
                  "value": "research-uuid-here",
                  "description": "Research UUID"
                },
                {
                  "key": "studentId",
                  "value": "student-uuid-here",
                  "description": "Student UUID to remove"
                }
              ]
            },
            "description": "Remove an author from research. Permanently deletes the author relationship.\n\nValidation:\n- Verifies author belongs to the specified research\n- Returns 404 if author not found\n- Returns 400 if author doesn't belong to this research"
          },
          "response": []
        },
        {
          "name": "Add Adviser to Research",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"faculty_id\": \"faculty-uuid-here\",\n  \"adviser_role\": \"co-adviser\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/research/:id/advisers",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "research", ":id", "advisers"],
              "variable": [
                {
                  "key": "id",
                  "value": "research-uuid-here",
                  "description": "Research UUID"
                }
              ]
            },
            "description": "Add an adviser to existing research.\n\nRequired fields:\n- faculty_id: Faculty UUID\n\nOptional fields:\n- adviser_role: Role description (e.g., 'primary adviser', 'co-adviser', 'panel member')\n\nValidation:\n- Prevents duplicate advisers (same faculty cannot be added twice)\n- Returns 409 Conflict if adviser already exists\n- Verifies faculty exists before adding"
          },
          "response": []
        },
        {
          "name": "Remove Adviser from Research",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/research/:id/advisers/:facultyId",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "research", ":id", "advisers", ":facultyId"],
              "variable": [
                {
                  "key": "id",
                  "value": "research-uuid-here",
                  "description": "Research UUID"
                },
                {
                  "key": "facultyId",
                  "value": "faculty-uuid-here",
                  "description": "Faculty UUID to remove"
                }
              ]
            },
            "description": "Remove an adviser from research. Permanently deletes the adviser relationship.\n\nValidation:\n- Verifies adviser belongs to the specified research\n- Returns 404 if adviser not found\n- Returns 400 if adviser doesn't belong to this research"
          },
          "response": []
        }
      ]
    }
  ]
}
