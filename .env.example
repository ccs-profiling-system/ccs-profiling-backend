# ============================================================================
# CCS Backend System - Environment Configuration
# ============================================================================
# This file documents all environment variables used by the CCS Backend System.
# Copy this file to .env and configure values for your environment.
#
# REQUIRED VARIABLES (must be set):
#   - DATABASE_URL
#   - JWT_SECRET
#   - JWT_REFRESH_SECRET
#
# OPTIONAL VARIABLES (have defaults):
#   - All other variables have sensible defaults for development
#
# SECURITY NOTES:
#   - NEVER commit .env files to version control
#   - Use strong, randomly generated secrets in staging/production
#   - Rotate JWT secrets periodically in production
#   - Use environment-specific database credentials
# ============================================================================

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
# Environment: development | staging | production | test
# - development: Local development with debug logging
# - staging: Pre-production testing environment
# - production: Live production environment with optimizations
# - test: Automated testing environment
NODE_ENV=development

# Server port
# Development: 3000
# Staging: 3001 or as configured by hosting provider
# Production: 3000 or as configured by hosting provider
PORT=3000

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?options
#
# REQUIRED - Must be set for all environments
#
# Development example (local PostgreSQL):
DATABASE_URL=postgresql://user:password@localhost:5432/ccs_profiling
#
# Staging example (cloud database with SSL):
# DATABASE_URL=postgresql://user:password@staging-db.example.com:5432/ccs_profiling_staging?sslmode=require
#
# Production example (cloud database with SSL and connection pooling):
# DATABASE_URL=postgresql://user:password@prod-db.example.com:5432/ccs_profiling_prod?sslmode=require&channel_binding=require
#
# SECURITY: Use strong passwords and restrict database access by IP

# Database Connection Pool Settings
# Adjust based on expected load and database server capacity
#
# Development: Small pool for local testing
DB_POOL_MAX=10
DB_POOL_MIN=2
#
# Staging: Medium pool for testing under load
# DB_POOL_MAX=20
# DB_POOL_MIN=5
#
# Production: Larger pool for high traffic
# DB_POOL_MAX=50
# DB_POOL_MIN=10

# Connection timeout settings (milliseconds)
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=30000

# ----------------------------------------------------------------------------
# JWT Authentication Configuration
# ----------------------------------------------------------------------------
# JWT secret for access tokens
# REQUIRED - Must be set for all environments
#
# SECURITY CRITICAL:
# - Use a strong, randomly generated secret (minimum 64 characters)
# - NEVER use the example values below in staging/production
# - Generate secrets using: openssl rand -base64 64
# - Rotate secrets periodically in production
#
# Development example (INSECURE - for local testing only):
JWT_SECRET=your-secret-key-here-replace-with-strong-random-value-min-64-chars
#
# Staging/Production: Generate using openssl rand -base64 64
# JWT_SECRET=<your-generated-secret-here>

# JWT refresh token secret (must be different from JWT_SECRET)
# REQUIRED - Must be set for all environments
#
# Development example (INSECURE - for local testing only):
JWT_REFRESH_SECRET=your-refresh-secret-key-here-replace-with-strong-random-value-min-64-chars
#
# Staging/Production: Generate using openssl rand -base64 64
# JWT_REFRESH_SECRET=<your-generated-secret-here>

# JWT token expiration times
# Format: number + unit (s=seconds, m=minutes, h=hours, d=days)
#
# Development: Longer expiration for convenience
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
#
# Production: Shorter expiration for security
# JWT_EXPIRES_IN=1h
# JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------------------------------------------------------
# File Upload Configuration
# ----------------------------------------------------------------------------
# Directory for uploaded files (relative to project root)
# Development: Local directory
UPLOAD_DIR=./uploads
#
# Production: Consider using absolute path or cloud storage
# UPLOAD_DIR=/var/app/uploads

# Maximum file size in bytes
# Default: 10485760 (10MB)
# Adjust based on your requirements and server capacity
MAX_FILE_SIZE=10485760
#
# For larger files (50MB):
# MAX_FILE_SIZE=52428800

# ----------------------------------------------------------------------------
# Storage Provider Configuration (Future Enhancement)
# ----------------------------------------------------------------------------
# Storage provider type: 'local' or 's3'
# Currently, only local storage is implemented
# S3 support is planned for future releases
STORAGE_PROVIDER=local

# Local Storage Configuration (when STORAGE_PROVIDER=local)
LOCAL_STORAGE_PATH=./uploads

# Reports Storage Configuration
REPORTS_STORAGE_PATH=./reports

# AWS S3 Storage Configuration (when STORAGE_PROVIDER=s3)
# Uncomment and configure when using S3 storage
# AWS_S3_BUCKET=your-bucket-name
# AWS_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_ENDPOINT=https://custom-s3-endpoint.com (optional, for S3-compatible services like MinIO)

# ----------------------------------------------------------------------------
# CORS Configuration
# ----------------------------------------------------------------------------
# Allowed origin for Cross-Origin Resource Sharing
# Controls which frontend domains can access the API
#
# Development: Local frontend development server
CORS_ORIGIN=http://localhost:5173
#
# Staging: Staging frontend URL
# CORS_ORIGIN=https://staging.example.com
#
# Production: Production frontend URL
# CORS_ORIGIN=https://app.example.com
#
# Multiple origins (comma-separated):
# CORS_ORIGIN=https://app.example.com,https://admin.example.com

# ============================================================================
# Environment-Specific Configuration Examples
# ============================================================================

# --- DEVELOPMENT ENVIRONMENT ---
# Use these settings for local development:
#
# NODE_ENV=development
# PORT=3000
# DATABASE_URL=postgresql://user:password@localhost:5432/ccs_profiling
# DB_POOL_MAX=10
# DB_POOL_MIN=2
# JWT_SECRET=dev-secret-key-replace-in-production
# JWT_REFRESH_SECRET=dev-refresh-secret-replace-in-production
# JWT_EXPIRES_IN=7d
# JWT_REFRESH_EXPIRES_IN=30d
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE=10485760
# CORS_ORIGIN=http://localhost:5173

# --- STAGING ENVIRONMENT ---
# Use these settings for staging/testing:
#
# NODE_ENV=staging
# PORT=3000
# DATABASE_URL=postgresql://user:password@staging-db.example.com:5432/ccs_profiling_staging?sslmode=require
# DB_POOL_MAX=20
# DB_POOL_MIN=5
# JWT_SECRET=<generate-with-openssl-rand-base64-64>
# JWT_REFRESH_SECRET=<generate-with-openssl-rand-base64-64>
# JWT_EXPIRES_IN=2h
# JWT_REFRESH_EXPIRES_IN=7d
# UPLOAD_DIR=/var/app/uploads
# MAX_FILE_SIZE=10485760
# CORS_ORIGIN=https://staging.example.com

# --- PRODUCTION ENVIRONMENT ---
# Use these settings for production:
#
# NODE_ENV=production
# PORT=3000
# DATABASE_URL=postgresql://user:password@prod-db.example.com:5432/ccs_profiling_prod?sslmode=require&channel_binding=require
# DB_POOL_MAX=50
# DB_POOL_MIN=10
# JWT_SECRET=<generate-with-openssl-rand-base64-64>
# JWT_REFRESH_SECRET=<generate-with-openssl-rand-base64-64>
# JWT_EXPIRES_IN=1h
# JWT_REFRESH_EXPIRES_IN=7d
# UPLOAD_DIR=/var/app/uploads
# MAX_FILE_SIZE=10485760
# CORS_ORIGIN=https://app.example.com

# ============================================================================
# Quick Start Guide
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Set required variables: DATABASE_URL, JWT_SECRET, JWT_REFRESH_SECRET
# 3. Generate JWT secrets: openssl rand -base64 64
# 4. Adjust optional variables as needed for your environment
# 5. Start the server: npm run dev
# ============================================================================
